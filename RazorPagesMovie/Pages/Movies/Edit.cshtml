@page "{id:int}"
@model RazorPagesMovie.Pages.Movies.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Movie</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Movie.Id" />
            <div class="form-group">
                <label asp-for="Movie.Title" class="control-label"></label>
                <input asp-for="Movie.Title" class="form-control" />
                <span asp-validation-for="Movie.Title" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Movie.ReleaseDate" class="control-label"></label>
                <input asp-for="Movie.ReleaseDate" class="form-control" />
                <span asp-validation-for="Movie.ReleaseDate" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Movie.Genre" class="control-label"></label>
                <input asp-for="Movie.Genre" class="form-control" />
                <span asp-validation-for="Movie.Genre" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Movie.Price" class="control-label"></label>
                <input asp-for="Movie.Price" class="form-control" />
                <span asp-validation-for="Movie.Price" class="text-danger"></span>
            </div>
            <div class="form-group">
                <span class="text-danger">*</span>
                <label asp-for="Movie.Rank" class="control-label"></label>
                <input asp-for="Movie.Rank" class="form-control" aria-required="true"/>
                <span asp-validation-for="Movie.Rank" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="hidden" asp-for="Movie.ImageUri" />               
                <label asp-for="Movie.ImageUri" class="control-label"></label>
                <input type="file" name="not-movie-image-uri" class="form-control" />
                <span asp-validation-for="Movie.ImageUri" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>

    <div class="col-md-8">
        @if (Model.Movie.ImageUri != null)
        {
            <img src="@Model.Movie.ImageUri" />
        }
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

