@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}


<div id="movieContent" class="row">
@foreach (var movie in Model.Movies)
{
    <div class="col-4">
        <div class="card m-1">
            <div class="card-body">
                <div class="row">
                    <div class="col-2 fw-bold">@Html.DisplayFor(m => movie.Rank)</div>
                    <div class="col-6 fw-bold">@movie.Title</div>
                    <div class="col-4 text-end fw-bold">@Html.DisplayFor(m => movie.Price)</div>
                </div>
                <div>
                    @if (!string.IsNullOrEmpty(movie.ImageUri))
                    {
                        <img src="@movie.ImageUri" alt="@movie.Title poster" style="height: 300px;" />
                    }
                </div>
                <div>@Html.DisplayFor(m => movie.ReleaseDate)</div>
                <div>@movie.Genre</div>
                <div><a asp-page="Details2" asp-route-id="@movie.Id" class="btn btn-primary">Details</a></div>
            </div>
        </div>
    </div>
}
</div>

<div class="row mt-5">
    <div class="col-md-6">
        <input type="number" id="xhrMovieId" placeholder="Enter movie ID">
        <button type="button" class="btn btn-info" onclick="fetchMovieWithXHR()">XMLHttpRequest</button>
        <div id="xhrMovieContent" class="mt-3"></div>
    </div>

    <div class="col-md-6">
        <input type="number" id="fetchMovieId" placeholder="Enter movie ID">
        <button type="button" class="btn btn-success" onclick="fetchMovieWithFetch()">fetch</button>
        <div id="fetchMovieContent" class="mt-3"></div>
    </div>
</div>

@section Scripts {
    <script>
        function createMovieCard(movie) {
            return `
                <div class="card">
                    <div class="card-body">
                        <div class="row mb-2">
                            <div class="col-2 fw-bold">${movie.rank}</div>
                            <div class="col-6 fw-bold">${movie.title}</div>
                            <div class="col-4 text-end fw-bold">$${movie.price.toFixed(2)}</div>
                        </div>
                        ${movie.imageUri ? `<div class="mb-2"><img src="${movie.imageUri}" alt="${movie.title} poster" style="height: 300px;" /></div>` : ''}
                        <div>${new Date(movie.releaseDate).toLocaleDateString()}</div>
                        <div>${movie.genre}</div>
                    </div>
                </div>
            `;
        }

        function fetchMovieWithXHR() {
            const movieId = document.getElementById('xhrMovieId').value;
            const contentDiv = document.getElementById('xhrMovieContent');

            if (!movieId) {
                contentDiv.innerHTML = '<div class="alert alert-warning">Please enter a movie ID</div>';
                return;
            }

            contentDiv.innerHTML = '<div class="spinner-border text-info" role="status"><span class="visually-hidden">Loading...</span></div>';

            const xhr = new XMLHttpRequest();
            xhr.open('GET', `/api/movies/${movieId}`, true);
            xhr.setRequestHeader('Content-Type', 'application/json');

            xhr.onload = function() {
                if (xhr.status === 200) {
                    const movie = JSON.parse(xhr.responseText);
                    contentDiv.innerHTML = createMovieCard(movie);
                    console.log('Movie loaded using XMLHttpRequest:', movie);
                } else if (xhr.status === 404) {
                    contentDiv.innerHTML = '<div class="alert alert-danger">Movie not found</div>';
                } else {
                    contentDiv.innerHTML = '<div class="alert alert-danger">Error loading movie</div>';
                }
            };

            xhr.onerror = function() {
                contentDiv.innerHTML = '<div class="alert alert-danger">Error connecting to server</div>';
                console.error('Error with XMLHttpRequest');
            };

            xhr.send();
        }

        function fetchMovieWithFetch() {
            const movieId = document.getElementById('fetchMovieId').value;
            const contentDiv = document.getElementById('fetchMovieContent');

            if (!movieId) {
                contentDiv.innerHTML = '<div class="alert alert-warning">Please enter a movie ID</div>';
                return;
            }

            contentDiv.innerHTML = '<div class="spinner-border text-success" role="status"><span class="visually-hidden">Loading...</span></div>';

            fetch(`/api/movies/${movieId}`, {
                method: 'GET',
                headers: {
                    'Content-Type': 'application/json'
                }
            })
            .then(response => {
                if (!response.ok) {
                    if (response.status === 404) {
                        throw new Error('Movie not found');
                    }
                    throw new Error('Network response was not ok');
                }
                return response.json();
            })
            .then(movie => {
                contentDiv.innerHTML = createMovieCard(movie);
                console.log('Movie loaded using Fetch API:', movie);
            })
            .catch(error => {
                if (error.message === 'Movie not found') {
                    contentDiv.innerHTML = '<div class="alert alert-danger">Movie not found</div>';
                } else {
                    contentDiv.innerHTML = '<div class="alert alert-danger">Error loading movie</div>';
                }
                console.error('Error with Fetch API:', error);
            });
        }
    </script>
}